{
  "family": "notes-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::266735814394:role/notes-task-execution-role",
  "taskRoleArn": "arn:aws:iam::266735814394:role/notes-task-role",
  "containerDefinitions": [
    {
      "name": "notes",
      "image": "<IMAGE1_NAME>",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/notes",
          "awslogs-region": "eu-central-1",
          "awslogs-stream-prefix": "notes"
        }
      }
    }
  ]
}
